# Built-in environments are "sandbox" (default) and "production".
# You can also define custom environments without changing code:
#   clink env add staging --api-base-url https://staging-api.clinkbill.com/api/ \
#     --dashboard-base-url https://staging-dashboard.clinkbill.com/prod-api/
#   clink --env staging auth status
# CLINK_ENV may name any built-in or custom environment.
CLINK_ENV=sandbox
# CLINK_BASE_URL overrides the resolved API base URL for the active environment.
CLINK_BASE_URL=https://uat-api.clinkbill.com/api/
CLINK_SECRET_KEY=sk_test_xxx
CLINK_WEBHOOK_SIGNING_KEY=whsec_xxx
